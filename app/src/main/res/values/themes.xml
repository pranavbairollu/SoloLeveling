<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.SoloLeveling" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/system_blue</item>
        <item name="colorPrimaryVariant">@color/system_blue_dim</item>
        <item name="colorOnPrimary">@color/black</item>
        
        <item name="colorSecondary">@color/system_blue</item>
        <item name="colorSecondaryVariant">@color/system_blue_dim</item>
        <item name="colorOnSecondary">@color/black</item>
        
        <item name="android:statusBarColor">@color/system_background_dark</item>
        <item name="android:windowBackground">@color/system_background_dark</item>
        <item name="android:textColor">@color/system_text_primary</item>
        
        <!-- Force Dark Mode -->
        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>
    </style>
    
    <!-- Text Styles -->
    <style name="SystemText">
        <item name="android:fontFamily">monospace</item>
        <item name="android:textColor">@color/system_text_primary</item>
    </style>
    
    <style name="SystemTitle" parent="SystemText">
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>